# Rename this file to .env and fill in your API keys
# Obtain API keys from the respective services

# Google Gemini API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Groq API Key
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"

# ComfyUI Server Address (default is 127.0.0.1:8188)
COMFYUI_SERVER_ADDRESS="127.0.0.1:8188"

# Path to your ComfyUI API workflow JSON file
# (e.g., one that takes positive/negative prompts and seed as input)
COMFYUI_WORKFLOW_FILE="assets/default_comfyui_workflow.json"

# Path to your endscreen video file (e.g., a short branding clip)
ENDSCREEN_VIDEO_FILE="assets/default_endscreen.mp4"

# (Optional) yt-dlp Cookies file location (for accessing restricted videos)
# YTDLP_COOKIES_FILE="path/to/your/cookies.txt"

# --- Kokoro TTS Configuration (Required for real TTS in Step 04) ---
# Download model & voices from: https://github.com/thewh1teagle/kokoro-onnx#available-models--voices
# Place them in a directory like 'assets/kokoro_models/'
KOKORO_MODEL_FILE_PATH="assets/kokoro_models/kokoro-v1.0.onnx"
KOKORO_VOICES_FILE_PATH="assets/kokoro_models/voices-v1.0.bin"
