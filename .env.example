# Rename this file to .env and fill in your API keys
# Obtain API keys from the respective services

# Google Gemini API Key
GEMINI_API_KEY="YOUR_GEMINI_API_KEY_HERE"

# Groq API Key
GROQ_API_KEY="YOUR_GROQ_API_KEY_HERE"

# ComfyUI Server Address (default is 127.0.0.1:8188)
COMFYUI_SERVER_ADDRESS="127.0.0.1:8188"

# Path to your ComfyUI API workflow JSON file
# (e.g., one that takes positive/negative prompts and seed as input)
COMFYUI_WORKFLOW_FILE="assets/default_comfyui_workflow.json"

# yt-dlp Cookies file location (optional, for accessing restricted videos)
# YTDLP_COOKIES_FILE="path/to/your/cookies.txt"
